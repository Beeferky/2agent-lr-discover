# Copy this file to .env and fill in your real credentials
# .env is gitignored — never commit real keys

# DashScope (Alibaba Cloud) for Qwen3.6-Plus agent calls
# Get yours at: https://dashscope.console.aliyun.com/
export DASHSCOPE_API_KEY="your_dashscope_api_key_here"

# Weights & Biases for training run logging
# Get yours at: https://wandb.ai/authorize
export WANDB_API_KEY="your_wandb_api_key_here"

# HuggingFace for dataset download (allenai/c4)
# Get yours at: https://huggingface.co/settings/tokens
export HF_TOKEN="your_hf_token_here"

# GPU configuration
# Comma-separated CUDA device IDs to use
export DEVICE="0,1,2,3"

# torchrun rendezvous port
export MASTER_PORT="29500"
